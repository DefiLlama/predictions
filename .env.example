NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prediction_markets
PG_BOSS_SCHEMA=ops

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_SCOPE_TOP_N=200
POLYMARKET_MAX_PAGES=100
POLYMARKET_TRADES_MAX_PAGES=20
POLYMARKET_BACKFILL_MAX_PAGES_PER_RUN=200
POLYMARKET_LOOKBACK_DAYS=7
PRICE_LOOKBACK_DAYS=7
POLYMARKET_LARGE_BET_USD_THRESHOLD=10000
POLYMARKET_TRADES_FILTER_MODE=all
POLYMARKET_METADATA_MODE=incremental

KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_MAX_PAGES=60
KALSHI_MULTIVARIATE_MAX_PAGES=30
KALSHI_TRADES_MAX_PAGES=20
KALSHI_EVENT_FALLBACK_MAX_PER_RUN=2000
TRADES_LOOKBACK_DAYS=7
OI_LOOKBACK_DAYS=7
INGEST_INCREMENTAL_OVERLAP_SECONDS=300
MARKET_RELINK_MAX_MARKETS_PER_RUN=50000
CATEGORY_BACKFILL_MAX_MARKETS_PER_RUN=5000

ENABLE_SCHEDULER=false
ACTIVE_POLL_INTERVAL_MS=300000
CLOSED_POLL_INTERVAL_MS=1800000
JOB_RUN_STALE_AFTER_MS=3600000
