{
  "name": "prediction_markets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "packageManager": "npm@10.x",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/cli/main.ts server",
    "dev:web": "npm run dev -w frontend",
    "start": "tsx src/cli/main.ts server",
    "start:api": "tsx src/cli/main.ts server",
    "build:web": "npm run build -w frontend",
    "start:web": "npm run start -w frontend",
    "cron:topn-live": "tsx src/cli/main.ts cron:topn-live",
    "cron:full-catalog": "tsx src/cli/main.ts cron:full-catalog",
    "cron:full-catalog:resume": "tsx src/cli/main.ts cron:full-catalog:resume",
    "ingest:metadata": "tsx src/cli/main.ts ingest:metadata",
    "ingest:metadata:backfill": "tsx src/cli/main.ts ingest:metadata:backfill",
    "ingest:prices": "tsx src/cli/main.ts ingest:prices",
    "ingest:orderbook": "tsx src/cli/main.ts ingest:orderbook",
    "ingest:trades": "tsx src/cli/main.ts ingest:trades",
    "ingest:oi": "tsx src/cli/main.ts ingest:oi",
    "ingest:kalshi:metadata": "tsx src/cli/main.ts ingest:kalshi:metadata",
    "ingest:kalshi:prices": "tsx src/cli/main.ts ingest:kalshi:prices",
    "ingest:kalshi:orderbook": "tsx src/cli/main.ts ingest:kalshi:orderbook",
    "ingest:kalshi:trades": "tsx src/cli/main.ts ingest:kalshi:trades",
    "ingest:kalshi:oi": "tsx src/cli/main.ts ingest:kalshi:oi",
    "ingest:relink-events": "tsx src/cli/main.ts ingest:relink-events",
    "ingest:categories": "tsx src/cli/main.ts ingest:categories",
    "ingest:categories:backfill": "tsx src/cli/main.ts ingest:categories:backfill",
    "ingest:rollups": "tsx src/cli/main.ts ingest:rollups",
    "ingest:all": "tsx src/cli/main.ts ingest:all",
    "verify:summary": "tsx src/cli/main.ts verify:summary",
    "verify:summary:strict": "tsx src/cli/main.ts verify:summary --strict",
    "db:create": "tsx src/db/create-database.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:prepare": "npm run db:create && npm run db:migrate && npm run db:seed",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
